# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL — production: AWS me-central-1 (Abu Dhabi) | PDPL compliant
DATABASE_URL="postgresql://user:password@localhost:5432/valura_uae"

# ─── Auth.js v5 ───────────────────────────────────────────────────────────────
AUTH_SECRET="your-secret-here"   # generate: openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# ─── Resend (email magic-link) ────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM="Valura <hello@valura.ae>"

# ─── PostHog (analytics) ──────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://..."
SENTRY_AUTH_TOKEN="..."
SENTRY_ORG="..."
SENTRY_PROJECT="valura-uae"

# NOTE: Production auth (Google SSO, Apple, Twilio OTP) will be wired by the tech team.
# Do not add those keys here until the providers are re-enabled in lib/auth.ts.
